# AlertWise — Environment Configuration
# Copy this file to .env and fill in your API keys.
# All keys are optional — alerts are enriched only for configured providers.
# Without keys, use --no-enrich for offline/demo mode.

# VirusTotal — https://www.virustotal.com/gui/my-apikey
# Free tier: 4 lookups/min, 500 lookups/day
VIRUSTOTAL_API_KEY=

# AbuseIPDB — https://www.abuseipdb.com/account/api
# Free tier: 1,000 checks/day
ABUSEIPDB_API_KEY=

# Shodan — https://account.shodan.io/
# Free tier: limited to network search
SHODAN_API_KEY=

# AlienVault OTX — https://otx.alienvault.com/api
# Free with registration
OTX_API_KEY=

# Optional: override cache directory (default: cache/)
# ALERTWISE_CACHE_DIR=cache